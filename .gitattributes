# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Shell scripts must keep LF even on Windows
*.sh text eol=lf
*.bash text eol=lf

# Batch files must keep CRLF on Windows
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.mp4 binary
*.mov binary
*.avi binary
*.mp3 binary
*.wav binary
