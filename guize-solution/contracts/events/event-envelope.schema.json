{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guize.local/contracts/events/event-envelope.schema.json",
  "title": "Guize Event Envelope",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "aggregateType",
    "aggregateId",
    "occurredAt",
    "producer",
    "traceId",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string"
    },
    "eventType": {
      "type": "string"
    },
    "eventVersion": {
      "type": "integer",
      "minimum": 1
    },
    "aggregateType": {
      "type": "string"
    },
    "aggregateId": {
      "type": "string"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string"
    },
    "traceId": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
